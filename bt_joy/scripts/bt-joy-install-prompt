#!/usr/bin/env bash
set -euo pipefail

bashrc="${BT_JOY_BASHRC:-$HOME/.bashrc}"
begin_marker="# >>> bt-joy prompt >>>"

touch "$bashrc"

if grep -Fq "$begin_marker" "$bashrc"; then
  echo "bt-joy prompt already exists in $bashrc"
  exit 0
fi

cat >> "$bashrc" <<'EOF'

# >>> bt-joy prompt >>>
if [ -n "$PS1" ] && [ -z "$BT_JOY_PROMPT_ACTIVE" ]; then
  export BT_JOY_PROMPT_ACTIVE=1
  PS1='${debian_chroot:+($debian_chroot)}🚀 \[\033[01;32m\]\u@\h\[\033[00m\]:\[\033[01;34m\]\w\[\033[00m\]\$ '
fi
# <<< bt-joy prompt <<<
EOF

echo "bt-joy prompt appended to $bashrc"
